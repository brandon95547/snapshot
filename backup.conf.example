# backup.conf — copy to backup.conf and edit for the production box.
# Every value here has a sane default in backup.sh; only override what differs.
# This file is sourced by backup.sh, so use shell syntax (KEY="value").

# --- What to back up -------------------------------------------------------

# Root of the deployed site code. On prod this is /var/www; on the dev box the
# apps live under /home/crimson/sites. NOTE: the script does NOT tar this whole
# tree — only the project dirs in PROJECT_DIRS below (WWW_DIR may hold huge
# unrelated things like a CosyVoice model checkout).
WWW_DIR="/var/www"

# The two project subdirectories inside WWW_DIR. Used to locate each app's
# .env, docker-compose files, and to name the DB source. Adjust if your prod
# layout differs (e.g. the api lives elsewhere).
PHANSORA_DIR="${WWW_DIR}/phansora"
PHANSORA_API_DIR="${WWW_DIR}/phansora-api"

# Exactly which directories get archived into www.tar.gz. Defaults to the two
# project dirs above — nothing else in WWW_DIR is included. Must live under
# WWW_DIR's parent (they're packed relative to it so restore lays them back out
# correctly). Add space-separated paths here to back up more.
PROJECT_DIRS="${PHANSORA_DIR} ${PHANSORA_API_DIR}"

# systemd unit files to grab (space separated, no path — they're looked up in
# /etc/systemd/system and its drop-in dirs). Each unit's ".d" drop-in directory
# (e.g. phansora-api.service.d) is captured automatically — no need to list it.
SYSTEMD_UNITS="phansora.service phansora-api.service phansora-book-worker.service"

# nginx and TLS certificate roots.
NGINX_DIR="/etc/nginx"
LETSENCRYPT_DIR="/etc/letsencrypt"

# --- Database --------------------------------------------------------------

# Name of the running Postgres container (see docker-compose.prod.yml:
# container_name: phansora_postgres). The DB lives in a Docker named volume,
# NOT on the filesystem, so a plain tar of /var/www will silently miss it.
# We take a logical pg_dump instead.
PG_CONTAINER="phansora_postgres"

# DB creds. Leave blank to auto-read DB_USER / DB_NAME from PHANSORA_DIR/.env.
DB_USER=""
DB_NAME=""

# --- Docker named volumes to snapshot (raw tar) ----------------------------
# Space-separated substrings; any docker volume whose name contains one of
# these is archived. Covers the phansora-api "media" volume. postgres_data is
# handled by pg_dump above, so it's intentionally not listed here.
VOLUME_MATCH="media"

# --- Output & retention ----------------------------------------------------

# Where completed backup archives are written.
BACKUP_ROOT="/var/backups/phansora"

# Delete backups older than this many days (0 = keep everything).
# Ignored when SINGLE_FILE=1 (there is only ever one archive).
RETENTION_DAYS=14

# Overwrite mode. Set to 1 to write ONE fixed archive that is replaced in place
# every run, instead of a new timestamped file each time. Use this for a
# frequent (e.g. hourly) cron where you only want the newest snapshot and don't
# want old backups piling up on disk. The archive is named "<SINGLE_FILE_NAME>.tar.gz"
# with a matching .log and a .json metadata sidecar (read by the admin dashboard).
SINGLE_FILE=1
SINGLE_FILE_NAME="phansora-backup-latest"

# Paths (relative to each dir being tarred) excluded from the code backup.
# These are large and rebuildable; the source of truth is git + package files.
EXCLUDES="node_modules .venv venv __pycache__ .pytest_cache .cache tmp .tmp_uploads output_audio output_txt"
